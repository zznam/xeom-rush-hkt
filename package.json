{
  "name": "xeom-rush-monorepo",
  "private": true,
  "scripts": {
    "dev:server": "pnpm build:shared && pnpm --filter server dev",
    "dev:client": "pnpm build:shared && pnpm --filter client dev",
    "build:shared": "pnpm --filter shared build",
    "build:server": "pnpm build:shared && pnpm --filter server build",
    "build:client": "pnpm build:shared && pnpm --filter client build",
    "start:server": "pnpm --filter server start",
    "test": "pnpm --filter shared test && pnpm build:shared && pnpm --filter server test",
    "test:e2e": "pnpm --filter e2e test",
    "bench": "pnpm --filter shared bench",
    "lint": "eslint . --max-warnings 0 && pnpm run lint:md",
    "lint:md": "markdownlint \"**/*.md\" --ignore node_modules --ignore dist",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "markdownlint-cli": "^0.44.0",
    "prettier": "^3.5.2",
    "typescript-eslint": "^8.24.1"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.md": [
      "markdownlint --fix",
      "prettier --write"
    ],
    "*.{json,html,css}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.28.2"
}
